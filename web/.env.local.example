# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (서버 사이드 전용, 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Drizzle 마이그레이션/시드용)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# MFDS / 식품안전나라 Open API (서버 사이드 전용)
FOODSAFETY_KOREA_API_KEY=your-foodsafetykorea-api-key

# 공공데이터포털 Open API (서버 사이드 전용)
# data.go.kr는 일반적으로 Encoding/Decoding 키를 모두 제공합니다.
DATA_GO_KR_SERVICE_KEY_ENCODED=your-url-encoded-service-key
DATA_GO_KR_SERVICE_KEY_DECODED=your-decoded-service-key

# OpenAI (제품 비교 AI 요약 - /api/compare/summary)
# 기본 모델은 gpt-5-mini 이며 OPENAI_COMPARE_MODEL 로 변경할 수 있습니다.
OPENAI_API_KEY=your-openai-api-key
# OPENAI_COMPARE_MODEL=gpt-5-mini

# ── Track B: 라벨 스크레이핑 ─────────────────────────────────────────────
# Naver Developers (https://developers.naver.com) — 쇼핑 컨테이너 API
#   애플리케이션 등록 → 검색(쇼핑) API 체크 → CLIENT ID/SECRET 발급
NAVER_SHOPPING_CLIENT_ID=
NAVER_SHOPPING_CLIENT_SECRET=

# Cloudflare R2 (S3 호환) — 제품 이미지 미러링 저장소
#   Dashboard → R2 → Create bucket (예: bochoong-product-images)
#   Manage R2 API Tokens → Account ID + Access Key 발급
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bochoong-product-images
# 공개 접근을 위해 R2 bucket → Public Access 또는 custom domain 연결
R2_PUBLIC_URL_BASE=https://pub-xxxxxxxx.r2.dev
