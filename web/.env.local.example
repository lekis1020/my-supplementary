# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (서버 사이드 전용, 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Drizzle 마이그레이션/시드용)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# MFDS / 식품안전나라 Open API (서버 사이드 전용)
FOODSAFETY_KOREA_API_KEY=your-foodsafetykorea-api-key

# 공공데이터포털 Open API (서버 사이드 전용)
# data.go.kr는 일반적으로 Encoding/Decoding 키를 모두 제공합니다.
DATA_GO_KR_SERVICE_KEY_ENCODED=your-url-encoded-service-key
DATA_GO_KR_SERVICE_KEY_DECODED=your-decoded-service-key

# OpenAI (제품 비교 AI 요약 - /api/compare/summary)
# 기본 모델은 gpt-5-mini 이며 OPENAI_COMPARE_MODEL 로 변경할 수 있습니다.
OPENAI_API_KEY=your-openai-api-key
# OPENAI_COMPARE_MODEL=gpt-5-mini
